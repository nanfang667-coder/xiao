// 这是 Prisma 的数据库结构定义文件。
// 我们在这里描述"老师"这张表有哪些字段，Prisma 会据此帮我们建数据库。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 一张"老师"表。每一行 = 一位老师。
model Teacher {
  id        Int      @id @default(autoincrement()) // 自动编号，1、2、3……
  name      String // 标题 / 老师名
  type      String // 类型："钢琴" 或 "舞蹈"
  city      String // 城市
  district  String // 区
  price     String // 价格
  services  String // 服务内容
  courseNotes String? // 教学案例/课程记录（可空，老数据没有）
  age       String? // 年龄（选填，支持单个数字或区间，如"28"、"25-30"）
  photos    String // 多张照片，存成一段 JSON 文本，例如 ["图1","图2"]
  emoji     String // 照片上的小图标（暂代真实图片）
  phone     String // 联系电话（会员可见）
  wechat    String // 微信号（会员可见）
  qq        String? // QQ（会员可见，可空）
  otherContact String? // 其他联系方式（会员可见，可空，如 Telegram/邮箱等）
  address   String? // 详细地址（会员可见，可空，帮学员判断通勤距离）
  createdAt DateTime @default(now()) // 创建时间，自动记录
  source    String?
  sourceId  Int?

  @@unique([source, sourceId])
  @@index([city, district, createdAt])
  @@index([createdAt])
}

// 用户表（普通用户）
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique // 登录账号，必须唯一
  email     String?  @unique // 绑定邮箱（选填，可为空；填了则必须唯一，不需要验证真实性）
  passwordHash String // 加密后的密码（不要存明文！）
  isMember  Boolean  @default(false) // 是否为会员
  membershipExpiresAt DateTime? // 会员到期时间（空表示永久或非会员）
  memberSince DateTime? // 最近一次从非会员变成会员的时间（用于统计新增会员），续费/延期不会更新这个时间
  referralCode String  @unique // 该用户自己的专属邀请码
  referredBy   Int?    // 谁邀请来的（User.id），只在注册时写入一次，此后不变
  registrationIp String? // 注册时的IP，用于识别同一IP短时间内批量注册
  isBanned  Boolean  @default(false) // 是否被封禁（自动检测批量注册，或管理员手动封禁）
  bannedAt  DateTime? // 封禁时间
  banReason String?   // 封禁原因
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 会员订单表。每一行 = 一笔开通会员的订单。
// 现在支付确认由页面按钮触发；未来接入支付宝/微信后，改由支付回调把 status 置为 paid。
model Order {
  id        Int      @id @default(autoincrement())
  userId    Int // 下单用户
  plan      String // 套餐名，如 "永久会员"
  amount    Float // 金额（元），如 38
  payMethod String // 支付方式："wechat" 微信 / "alipay" 支付宝
  status    String   @default("pending") // pending 待支付 / paid 已支付
  merchantOrderNo String? @unique // 本站提交给支付平台的唯一订单号
  providerTradeNo String? @unique // 支付平台订单号
  paymentUrl String? // 支付平台返回的收银台地址
  paymentExpiresAt DateTime? // 收银台地址过期时间
  paymentCheckedAt DateTime? // 最近一次主动查单时间（用于限流）
  createdAt DateTime @default(now())
  paidAt    DateTime? // 支付完成时间
}

// 推广佣金记录。每一行 = 一笔"被邀请人开通会员"产生的佣金。
// orderId 加 unique：保证一笔订单只能产生一次佣金，防止重复入账。
model Commission {
  id           Int      @id @default(autoincrement())
  referrerId   Int // 拿佣金的人（推荐人）
  orderId      Int      @unique // 对应哪笔会员订单
  amount       Float // 佣金金额（人民币）
  withdrawalId Int? // 归入哪一笔提现申请；还没提现时为 null
  createdAt    DateTime @default(now())
}

// 提现申请。每一行 = 一次佣金提现请求（人工审核后手动转账）。
model Withdrawal {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Float // 本次提现总额（人民币）
  payMethod   String // 收款方式："usdt" / "alipay" / "wechat"
  account     String // 收款账号：USDT地址 / 支付宝账号 / 微信收款码或账号
  network     String? // 仅 payMethod 为 "usdt" 时使用，网络类型如 "TRC20"
  status      String   @default("pending") // pending 待处理 / paid 已发放 / rejected 已驳回
  createdAt   DateTime @default(now())
  paidAt      DateTime?
}

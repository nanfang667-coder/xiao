// 这是 Prisma 的数据库结构定义文件。
// 我们在这里描述"老师"这张表有哪些字段，Prisma 会据此帮我们建数据库。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 一张"老师"表。每一行 = 一位老师。
model Teacher {
  id        Int      @id @default(autoincrement()) // 自动编号，1、2、3……
  name      String // 标题 / 老师名
  type      String // 类型："钢琴" 或 "舞蹈"
  city      String // 城市
  district  String // 区
  price     String // 价格
  services  String // 服务内容
  process   String? // 过程介绍（可空，老数据没有）
  photos    String // 多张照片，存成一段 JSON 文本，例如 ["图1","图2"]
  emoji     String // 照片上的小图标（暂代真实图片）
  phone     String // 联系电话（会员可见）
  wechat    String // 微信号（会员可见）
  qq        String? // QQ（会员可见，可空）
  createdAt DateTime @default(now()) // 创建时间，自动记录
}

// 用户表（普通用户）
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique // 登录账号，必须唯一
  email     String   @unique // 绑定邮箱，必须唯一（但不需要验证）
  passwordHash String // 加密后的密码（不要存明文！）
  isMember  Boolean  @default(false) // 是否为会员
  membershipExpiresAt DateTime? // 会员到期时间（空表示永久或非会员）
  referralCode String  @unique // 该用户自己的专属邀请码
  referredBy   Int?    // 谁邀请来的（User.id），只在注册时写入一次，此后不变
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 会员订单表。每一行 = 一笔开通会员的订单。
// 现在支付确认由页面按钮触发；未来接入支付宝/微信后，改由支付回调把 status 置为 paid。
model Order {
  id        Int      @id @default(autoincrement())
  userId    Int // 下单用户
  plan      String // 套餐名，如 "永久会员"
  amount    Float // 金额（元），如 38
  payMethod String // 支付方式："wechat" 微信 / "alipay" 支付宝
  status    String   @default("pending") // pending 待支付 / paid 已支付
  createdAt DateTime @default(now())
  paidAt    DateTime? // 支付完成时间
}

// 推广佣金记录。每一行 = 一笔"被邀请人开通会员"产生的佣金。
// orderId 加 unique：保证一笔订单只能产生一次佣金，防止重复入账。
model Commission {
  id           Int      @id @default(autoincrement())
  referrerId   Int // 拿佣金的人（推荐人）
  orderId      Int      @unique // 对应哪笔会员订单
  amount       Float // 佣金金额（人民币）
  withdrawalId Int? // 归入哪一笔提现申请；还没提现时为 null
  createdAt    DateTime @default(now())
}

// 提现申请。每一行 = 一次佣金提现请求（人工审核后手动转 USDT）。
model Withdrawal {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Float // 本次提现总额（人民币计价，实际按当时汇率手动转账）
  usdtAddress String // 收款 USDT 地址
  network     String // 网络类型，如 "TRC20"
  status      String   @default("pending") // pending 待处理 / paid 已发放 / rejected 已驳回
  createdAt   DateTime @default(now())
  paidAt      DateTime?
}
